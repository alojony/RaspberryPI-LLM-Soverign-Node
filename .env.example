# ── LLM ────────────────────────────────────────────────────
MODEL_PATH=/data/models/qwen2.5-3b-instruct-q4_k_m.gguf
LLM_HOST=llm
LLM_PORT=8080
LLM_CTX=4096
LLM_THREADS=4

# ── Embeddings ──────────────────────────────────────────────
EMBED_HOST=embeddings
EMBED_PORT=8001
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384

# ── Qdrant ──────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=pi_node

# ── API ─────────────────────────────────────────────────────
API_PORT=8000
API_HOST=0.0.0.0
SECRET_KEY=change-me-before-deploy

# ── Search tool ─────────────────────────────────────────────
SEARCH_API_KEY=
SEARCH_PROVIDER=ddg              # ddg | brave | serper

# ── Ingestion ───────────────────────────────────────────────
VAULT_PATH=/data/vault           # mount your Obsidian vault here
CHUNK_SIZE=1600
CHUNK_OVERLAP=400

# ── Scheduler / Utility ─────────────────────────────────────
TZ=America/Chicago
LOCAL_TZ=UTC          # your local timezone, e.g. Europe/London, America/New_York
DATABASE_URL=sqlite:////data/db/pi_node.db
WEATHER_LOCATION=Sacramento,CA   # city for weather widget
BRIEFING_TIME=08:00              # daily briefing generation time (local TZ)

# ── Notion ──────────────────────────────────────────────────
NOTION_TOKEN=                          # Internal Integration Token from notion.so/my-integrations
NOTION_DATABASE_IDS=                   # Comma-separated database IDs to ingest into RAG
NOTION_CALENDAR_DB_ID=                 # Single database ID whose Date pages become calendar events

# ── Google Calendar ──────────────────────────────────────────
GCAL_CREDENTIALS_PATH=/data/db/gcal_credentials.json   # OAuth2 client secret downloaded from GCP Console
GCAL_TOKEN_PATH=/data/db/gcal_token.json               # Auto-written after first OAuth flow
GCAL_REDIRECT_URI=http://localhost:8000/calendar/callback

# ── Resource limits (simulate Pi 5) ─────────────────────────
# Set in docker-compose.yml — do not override here unless testing
